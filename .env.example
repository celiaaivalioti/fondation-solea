NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-09

# Outgoing mail for the contact and registration forms (Infomaniak mailbox).
# Set these in the Node.js hosting environment variables in production.
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_USER=contact@fondation-solea.ch
SMTP_PASSWORD=the-mailbox-password
CONTACT_FORM_TO=contact@fondation-solea.ch
